{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/",
      "destination": "/index.html"
    },
    {
      "source": "/heatmap",
      "destination": "/index.html"
    },
    {
      "source": "/stocks/:symbol",
      "destination": "/stock-detail.html"
    }
  ]
}
